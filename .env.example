# =============================================================
# DOPA WORK — ENVIRONMENT VARIABLES TEMPLATE
# =============================================================
# 1. Copy this file:   cp .env.example .env
# 2. Fill in ALL values marked with <CHANGE_ME>
# 3. NEVER commit .env to version control (.gitignore covers it)
# =============================================================

# ─── APP ─────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001
FRONTEND_URL=https://yourdomain.com
BACKEND_URL=https://yourdomain.com/api/v1

# ─── DATABASE ────────────────────────────────────────────────
# Generate strong password: openssl rand -base64 32
DB_HOST=postgres
DB_PORT=5432
DB_NAME=freelance_db
DB_USER=freelance_user
DB_PASSWORD=<CHANGE_ME_use_openssl_rand_-base64_32>

# ─── REDIS ───────────────────────────────────────────────────
# Generate strong password: openssl rand -base64 32
REDIS_PASSWORD=<CHANGE_ME_use_openssl_rand_-base64_32>
REDIS_URL=redis://:<REDIS_PASSWORD>@redis:6379

# ─── JWT ─────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=<CHANGE_ME_use_openssl_rand_-hex_64>
JWT_REFRESH_SECRET=<CHANGE_ME_use_openssl_rand_-hex_64>
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── ADMIN SEED ──────────────────────────────────────────────
# Used only by: npm run seed:admin (run once after first deploy)
# NOT read by the application at runtime.
ADMIN_EMAIL=<CHANGE_ME_admin@yourdomain.com>
ADMIN_PASSWORD=<CHANGE_ME_min_8chars_uppercase_digit_special>

# ─── STRIPE (optional — leave empty to use local payment methods only) ─
# NEVER expose STRIPE_SECRET_KEY to the frontend
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret_here

# ─── LOCAL PAYMENT INSTRUCTIONS (Dopa Work) ────────────────────
# Shown to client when paying via CliQ / Bank / Zain Cash / Orange Money
BANK_IBAN=JO00XXXX0000000000000000000000
BANK_NAME=Platform Bank
CLIQ_ALIAS=DOPAWORK.JO
MOBILE_PAYMENT_NUMBER=+962 7X XXX XXXX

# ─── GOOGLE OAUTH ────────────────────────────────────────────
GOOGLE_CLIENT_ID=<CHANGE_ME>.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=<CHANGE_ME>
GOOGLE_CALLBACK_URL=https://yourdomain.com/api/auth/google/callback

# ─── FRONTEND (build args for Next.js) ──────────────────────
NEXT_PUBLIC_API_URL=https://yourdomain.com/api/v1
NEXT_PUBLIC_SOCKET_URL=https://yourdomain.com

# ─── EMAIL (SMTP) ────────────────────────────────────────────
SMTP_HOST=smtp.yourmailprovider.com
SMTP_PORT=587
SMTP_USER=noreply@yourdomain.com
SMTP_PASS=<CHANGE_ME>
SMTP_FROM=noreply@yourdomain.com
EMAIL_FROM="Dopa Work <noreply@yourdomain.com>"

# ─── PUPPETEER ───────────────────────────────────────────────
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium

# ─── PLATFORM CONFIG ─────────────────────────────────────────
COMMISSION_RATE=10
MIN_WITHDRAWAL_JOD=20
MAX_UPLOAD_SIZE_MB=25
