# ─── TEST ENVIRONMENT VARIABLES ───────────────────────────────────────────────
# Copy to .env.test and fill in values for running integration + E2E tests.
# These are ONLY needed for tests that hit a live database (marked "requires live DB").
# Auth/guard tests that only check 401/400 responses work WITHOUT these vars.

# ── Backend DB (same as .env for test DB) ───────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=yourpassword
DB_NAME=freelance_test
JWT_SECRET=your-jwt-secret
JWT_REFRESH_SECRET=your-refresh-secret
REDIS_PASSWORD=yourredispassword

# ── Frontend base URL for Playwright ────────────────────────────────────────
PLAYWRIGHT_BASE_URL=http://localhost:3002

# ── Pre-seeded test user tokens ─────────────────────────────────────────────
# Generate with: POST /api/v1/auth/login → copy access_token
TEST_USER_TOKEN=eyJhbGci...          # any verified user
TEST_CLIENT_TOKEN=eyJhbGci...        # verified CLIENT role user
TEST_FREELANCER_TOKEN=eyJhbGci...    # verified FREELANCER role user
TEST_ADMIN_TOKEN=eyJhbGci...         # admin/super_admin role user
TEST_UNVERIFIED_TOKEN=eyJhbGci...    # user with email_verified=false

# ── Pre-seeded test user credentials (for Playwright login) ─────────────────
TEST_CLIENT_EMAIL=testclient@example.com
TEST_CLIENT_PASSWORD=Test1234!
TEST_FREELANCER_EMAIL=testfreelancer@example.com
TEST_FREELANCER_PASSWORD=Test1234!
TEST_ADMIN_EMAIL=testadmin@example.com
TEST_ADMIN_PASSWORD=Test1234!

# ── Pre-seeded entity IDs ────────────────────────────────────────────────────
# These must exist in the test database before running tests.
TEST_PENDING_ORDER_ID=         # An order with status='pending' owned by TEST_CLIENT
TEST_DELIVERED_ORDER_ID=       # An order with status='delivered' owned by TEST_CLIENT
TEST_OTHER_ORDER_ID=           # An order belonging to a DIFFERENT user (IDOR test)
TEST_PENDING_TX_ID=            # A transaction with type='deposit' status='pending'
TEST_OTHER_USER_TX_ID=         # A transaction belonging to a DIFFERENT user

TEST_FREELANCER_CONTRACT_ID=   # Active contract where TEST_FREELANCER is the freelancer
TEST_COMPLETED_CONTRACT_ID=    # A contract with status='completed'
TEST_OTHER_CONTRACT_ID=        # A contract neither test user is part of

TEST_PENDING_MILESTONE_ID=     # A milestone with status='pending'

TEST_DISPUTE_ID=               # An open dispute
TEST_ADMIN_TOKEN=              # Admin JWT (duplicate — set above)

TEST_CHAT_ROOM_ID=             # Chat room shared by TEST_CLIENT and TEST_FREELANCER
TEST_OTHER_CHAT_ROOM_ID=       # Chat room belonging to other users (access denied test)

TEST_OTHER_PROJECT_ID=         # Project belonging to another client
TEST_FREELANCER_PROFILE_URL=/freelancers  # URL to a freelancer profile page

# ── Optional ─────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=             # Leave empty to test "Stripe not configured" path
