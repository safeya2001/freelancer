# Frontend Environment Variables
# Copy this file to .env.local for local development

# ─── API ───────────────────────────────────────────────────
# URL of the backend API (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:3001

# ─── WebSocket ─────────────────────────────────────────────
# URL for Socket.IO connection (same host as backend usually)
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001

# ─── Stripe ────────────────────────────────────────────────
# Publishable key only — NEVER put the secret key here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx

# ─── Google OAuth (optional — for social sign-in button) ───
NEXT_PUBLIC_GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com

# ─── App Meta ──────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=Freelance.jo
NEXT_PUBLIC_APP_URL=http://localhost:3000
